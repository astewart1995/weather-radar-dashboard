<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8" />
<meta name="viewport" content="width=device-width, initial-scale=1.0"/>

<title>Live Weather Radar</title>

<link rel="stylesheet" href="https://unpkg.com/leaflet@1.9.4/dist/leaflet.css"/>
<script src="https://unpkg.com/leaflet@1.9.4/dist/leaflet.js"></script>

<style>
html, body {
    margin:0;
    padding:0;
    height:100%;
    width:100%;
    overflow:hidden;
    background:#0b0f14;
    font-family: Arial, sans-serif;
}

#map {
    position:absolute;
    top:0;
    bottom:0;
    width:100%;
}

/* TOP BAR */
#topBar {
    position:absolute;
    top:0;
    left:0;
    right:0;
    height:50px;
    background:rgba(10,14,20,0.75);
    display:flex;
    justify-content:space-between;
    align-items:center;
    padding:0 15px;
    z-index:1000;
    border-bottom:1px solid rgba(0,191,255,0.3);
    backdrop-filter: blur(8px);
}

#title {
    color:#00d4ff;
    font-weight:bold;
    letter-spacing:2px;
}

#clock {
    color:white;
    font-size:14px;
}

/* STATION MARKER */
.pulse {
    width:14px;
    height:14px;
    border-radius:50%;
    background:#00d4ff;
    border:2px solid white;
    box-shadow:0 0 10px #00d4ff;
    animation:pulse 1.4s infinite;
}

@keyframes pulse {
    0% {transform:scale(1); opacity:1;}
    70% {transform:scale(2); opacity:0.2;}
    100% {transform:scale(1); opacity:1;}
}
</style>
</head>

<body>

<div id="topBar">
    <div id="title">LIVE WEATHER RADAR</div>
    <div id="clock">--:--</div>
</div>

<div id="map"></div>

<script>

// ======================
// YOUR LOCATION
// ======================
const station = [36.1209302, -87.6574700];

// ======================
// MAP
// ======================
const map = L.map('map', {
    center: station,
    zoom: 9,
    zoomControl: true
});

// Dark base map
L.tileLayer('https://{s}.basemaps.cartocdn.com/dark_all/{z}/{x}/{y}{r}.png', {
    attribution: '© OpenStreetMap © CARTO'
}).addTo(map);

// Radar pane
map.createPane("radarPane");
map.getPane("radarPane").style.zIndex = 400;

// ======================
// CLOCK
// ======================
function updateClock() {
    const el = document.getElementById("clock");
    const now = new Date();
    el.innerText = now.toLocaleTimeString([], {
        hour:'2-digit',
        minute:'2-digit'
    });
}
setInterval(updateClock, 1000);
updateClock();

// ======================
// STATION MARKER
// ======================
const icon = L.divIcon({
    className: "",
    html: '<div class="pulse"></div>',
    iconSize: [14,14],
    iconAnchor: [7,7]
});

L.marker(station, { icon }).addTo(map);

// ======================
// TENNESSEE BOUNDARY
// ======================
fetch("https://raw.githubusercontent.com/PublicaMundi/MappingAPI/master/data/geojson/us-states.json")
.then(r => r.json())
.then(data => {

    L.geoJSON(data, {
        style: f => ({
            color: f.properties.name === "Tennessee" ? "#00ffff" : "#444",
            weight: f.properties.name === "Tennessee" ? 3 : 1,
            fillOpacity: 0
        })
    }).addTo(map);

});

// ======================
// RADAR (REAL WORKING)
// ======================
let radarLayer;

function loadRadar() {

    const now = new Date().getTime();

    const url =
    "https://tilecache.rainviewer.com/v2/radar/nowcast_0.png?t=" + now;

    if (radarLayer) {
        map.removeLayer(radarLayer);
    }

    radarLayer = L.tileLayer(url, {
        opacity: 0.6,
        pane: "radarPane"
    });

    radarLayer.addTo(map);
}

// refresh radar every 2 minutes
loadRadar();
setInterval(loadRadar, 120000);

</script>

</body>
</html>
